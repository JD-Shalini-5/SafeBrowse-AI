{
  "manifest_version": 3,
  "name": "SafeBrowse AI",
  "version": "1.1.0",
  "description": "Instant on-device safety layer for filtering trigger topics.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/tf.min.js",
        "lib/use.min.js",
        "lib/mobilenet.min.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}